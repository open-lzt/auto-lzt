{
  "name": "Lot title builder",
  "entry_node_id": "build",
  "params": [
    { "key": "prefix", "label": "Префикс", "control": "text", "required": true, "default": "[SALE] " },
    { "key": "title", "label": "Название", "control": "text", "required": true, "default": "Steam account" }
  ],
  "nodes": [
    {
      "id": "build",
      "type": "logic.string_concat",
      "inputs": {
        "a": { "literal": "{{vars.prefix}}" },
        "b": { "literal": "{{vars.title}}" }
      }
    }
  ]
}
