# --- Docker Compose infra credentials (read by docker-compose.yml interpolation, NOT by the app) ---
# The compose stack builds the api/worker DB + Redis URLs from these, so server and clients share one
# source. Demo defaults: postgres password `lzt`, redis no auth. CHANGE BOTH before exposing the
# stack beyond localhost. (These do not apply to the no-Docker `uv run python dev.py` loop, which
# uses the LZT_FLOW_DATABASE_URL / LZT_FLOW_REDIS_URL localhost values below.)
POSTGRES_PASSWORD=lzt
REDIS_PASSWORD=

# lzt-flow's own config surface (prefix LZT_FLOW_). The URLs below are for the non-Docker dev loop;
# under docker compose the api/worker get service-network URLs built from POSTGRES_PASSWORD/REDIS_PASSWORD.
LZT_FLOW_DATABASE_URL=postgresql+asyncpg://lzt:lzt@localhost:5432/lztflow
LZT_FLOW_REDIS_URL=redis://localhost:6379/0
# Envelope master key for account-token encryption. Generate: python -c "from cryptography.fernet import Fernet;print(Fernet.generate_key().decode())"
LZT_FLOW_MASTER_KEY=
# Wave-1 single token for POST /debug/bump (retired in Wave 3).
LZT_FLOW_DEBUG_TOKEN=
# Shared secret required on mutating endpoints via X-API-Key. Empty disables the gate — fine for a loopback-only self-host, set this before exposing the API beyond localhost.
LZT_FLOW_API_KEY=
LZT_FLOW_WORKER_ID=worker-1
LZT_FLOW_DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000001
# Hosts a request node may reach. EMPTY = no egress (fail-closed). Comma-separated: "a.com, b.com".
LZT_FLOW_EGRESS_ALLOWED_HOSTS=
# Allow-list prefix for a flow's {"env": NAME} inputs — a flow may only read host vars starting with
# this, so it cannot name LZT_FLOW_MASTER_KEY. Must be non-empty.
LZT_FLOW_FLOW_ENV_PREFIX=FLOW_

# --- Telegram admin bot (prefix LZT_FLOW_BOT_) — the owner's control surface. Off unless enabled. ---
LZT_FLOW_BOT_ENABLED=0
LZT_FLOW_BOT_TOKEN=
# Comma-separated Telegram user ids allowed to use the bot. Empty = the bot answers nobody.
LZT_FLOW_BOT_ADMIN_IDS=
LZT_FLOW_BOT_API_BASE_URL=http://127.0.0.1:8000
LZT_FLOW_BOT_API_KEY=

# --- Owner-only plugin runtime (prefix LZT_FLOW_) — install .py plugins from the bot ---
# Folder holding bot-installed plugins (<name>/{manifest.json, plugin.py}). Applied on restart.
LZT_FLOW_PLUGIN_DIR=.system/plugins
# Trusted git-hosted plugins.json catalog (e.g. open-lzt/lzt-plugins). EMPTY disables install-from-bot.
LZT_FLOW_PLUGIN_INDEX_URL=https://raw.githubusercontent.com/open-lzt/lzt-plugins/main/plugins.json
# GitHub PAT (repo read scope) if the catalog repo is PRIVATE; empty for a public catalog.
LZT_FLOW_PLUGIN_INDEX_TOKEN=
# How often (s) the bot checks the catalog for updates (both toggles default OFF, set in the bot).
LZT_FLOW_PLUGIN_UPDATE_INTERVAL_S=3600
# Override the bundled notification texts (app/plugin_runtime/texts.toml). Empty = bundled.
LZT_FLOW_PLUGIN_TEXTS_PATH=

# --- lzt-eventus's EngineConfig surface (prefix LZT_), added in Wave 5 (decisions #21/#24) ---
# SEPARATE surface from lzt-flow's Settings above: polling tokens live here, action tokens live
# in the `accounts` table. Only needed to run the on-event path (the embedded engine needs Postgres).
LZT_TOKENS=
# Fernet-compatible key encrypting stored poll tokens at rest — DISTINCT from LZT_FLOW_MASTER_KEY.
LZT_TOKEN_ENC_KEY=
# Same Postgres instance as LZT_FLOW_DATABASE_URL is fine (eventus uses its own tables); bare DSN.
LZT_DATABASE_URL=postgresql://lzt:lzt@localhost:5432/lztflow
LZT_REDIS_URL=redis://localhost:6379/0
LZT_ADMIN_API_KEY=
LZT_ADVISORY_LOCK_KEY=1819044195
LZT_CATEGORIES=steam
